{
  "baseURL": "https://app.example.com",
  "localStorageState": ".webperf/auth-tokens.json",
  "runs": 5,
  "headless": true,
  "outputDir": ".webperf",
  "budgetMetric": "median",
  "defaults": {
    "readyVisible": "[data-test=main-chart]",
    "readyHidden": "[data-test=loading]",
    "navigationTimeoutMs": 60000,
    "readyTimeoutMs": 60000,
    "readyHiddenTimeoutMs": 15000,
    "endpointWatch": [
      {
        "id": "salesSummary",
        "urlIncludes": "/api/dashboard/sales-summary",
        "method": "GET",
        "maxCalls": 2
      }
    ]
  },
  "pages": [
    {
      "url": "/dashboard/sales",
      "maxReadyMs": 4000,
      "readyVisible": "[data-test=sales-chart]",
      "endpointWatch": [
        {
          "id": "aggregateApi",
          "urlRegex": "^https://[^/]+/api/sales/aggregate(?:\\?.*)?$",
          "urlRegexFlags": "i",
          "method": "GET",
          "maxCalls": 1,
          "maxTotalResponseBytes": 500000
        }
      ]
    }
  ]
}