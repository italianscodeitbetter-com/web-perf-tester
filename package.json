{
  "name": "@icib.dev/perf-web-tester",
  "version": "0.0.1",
  "description": "Playwright-based web page performance testing with JSON config and CI-friendly budgets",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "icib-perf-web-tester": "dist/cli.js",
    "icib-perf-add-check": "dist/init-check.js"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "README.md",
    "AGENTS.md",
    "LICENSE",
    "perf.config.example.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "perf": "node dist/cli.js",
    "perf:init": "node dist/cli.js init",
    "perf:add-check": "node dist/init-check.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "playwright": "^1.49.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "playwright",
    "performance",
    "web",
    "testing",
    "e2e"
  ]
}
